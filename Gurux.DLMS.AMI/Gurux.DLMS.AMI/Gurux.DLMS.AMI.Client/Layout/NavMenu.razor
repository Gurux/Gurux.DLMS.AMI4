@using System.Diagnostics
@using Gurux.DLMS.AMI.Shared.Rest
@implements IDisposable
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<NavMenu> Logger
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PersistentComponentState State
@inject IGXNotifier2 Notifier

@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Gurux.DLMS.AMI</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (_menu?.Links != null)
        {
            @foreach (var link in _menu.Links)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="@link.Url" Match="@GetPrefix(link.Url)">
                        @if (!string.IsNullOrEmpty(link.Icon))
                        {
                            <Image Id="@link.Icon"></Image>
                        }
                        <LocalizedText Value="@link.Name" />
                        @if (!string.IsNullOrEmpty(link.Padges))
                        {
                            <Badge Value="@ClientHelpers.GetBadgeCount(_updateStamps, link.Padges)"
                                   Label="@link.PadgeTitle"
                                   TraceLevel="@ClientHelpers.GetBadgeTraceLevel(_updateStamps, link.Padges)">
                            </Badge>
                        }
                    </NavLink>
                </div>
            }
        }
    </nav>
</div>

@code {

    private NavLinkMatch GetPrefix(string? url)
    {
        if (url == "/")
        {
            return NavLinkMatch.All;
        }
        return NavLinkMatch.Prefix;
    }



    private string? currentUrl;
    private GXMenu? _menu;

    //Language has changed.
    public void LanguageUpdated()
    {
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// User stamps.
    /// </summary>
    private List<GXUserStamp> _updateStamps = new();

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        _menu = (await Http.GetAsJsonAsync<GetMenuResponse>(string.Format("api/Menu/name?name={0}", GXMenus.NavMenu)))?.Item;
        try
        {
            _updateStamps.Clear();
            _updateStamps.AddRange(Notifier.GetUserStamps(ClientHelpers.GetBadges(_menu)));
            ClientHelpers.GetUserStamps(_menu, _updateStamps);
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                Notifier.On<IEnumerable<GXUserStamp>>(this, nameof(IGXHubEvents.StampUpdate), (stamps) =>
                {
                    bool updated = ClientHelpers.UpdateUserStamps(stamps, _updateStamps);
                    if (updated)
                    {
                        InvokeAsync(StateHasChanged);
                    }
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An error occurred.");
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        Notifier.RemoveListener(this);
    }
}

