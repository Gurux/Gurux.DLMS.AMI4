@using Gurux.DLMS.AMI.Shared.DTOs.Authentication
@if (Creator != null)
{
    <AuthoringInformation CREATIONTIME="global::System.DateTimeOffset"
                          Action="@Action"
                          Creator="@Creator" CreatorChanged="@CreatorChanged"
                          CreationTime="@CreationTime"
                          Updated="@Updated"
                          Removed="@Removed" RemovedChanged="@RemovedChanged" />
}
@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public GXUser? Creator { get; set; }
    [Parameter] public EventCallback<GXUser?> CreatorChanged { get; set; }

    [Parameter] public DateTimeOffset? CreationTime { get; set; }
    [Parameter] public EventCallback<DateTimeOffset?> CreationTimeChanged { get; set; }

    [Parameter] public DateTimeOffset? Updated { get; set; }
    [Parameter] public DateTimeOffset? Removed { get; set; }
    [Parameter] public EventCallback<DateTimeOffset?> RemovedChanged { get; set; }
}