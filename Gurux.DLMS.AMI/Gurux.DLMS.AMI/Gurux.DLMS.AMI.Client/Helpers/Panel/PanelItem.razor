@namespace Gurux.DLMS.AMI.Components.Panel

@code {
    [CascadingParameter]
    private Panel? Parent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? Style { get; set; }   

    /// <summary>
    /// Width.
    /// </summary>
    [Parameter]
    public string? Width
    {
        get;
        set;
    }

    /// <summary>
    /// Height.
    /// </summary>
    [Parameter]
    public string? Height
    {
        get;
        set;
    }

    protected override async Task OnInitializedAsync()
    {
        if (Parent == null)
        {
            throw new ArgumentNullException(nameof(Parent), "Panel item must exist within a Panel");
        }
        await base.OnInitializedAsync();
        await Parent.AddItem(this);
    }
}