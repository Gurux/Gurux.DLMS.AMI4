@using Gurux.DLMS.AMI.Client.Pages.User
@using Gurux.DLMS.AMI.Shared.DTOs.Authentication

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<CreatorSelector> Logger
@if (Action != "Add")
{
    <div class="form-group">
        <label>@Properties.Resources.Creator</label>
        <UserSelector Disabled="@(!IsAdmin)" @bind-Value="@Target"></UserSelector>
        <ValidationMessage For="@(() => @Target)" />
    </div>
}

@code {

    /// <summary>
    /// Target user.
    /// </summary>
    [Parameter]
    public GXUser? Target { get; set; }

    /// <summary>
    /// User action.
    /// </summary>
    [Parameter]
    public string? Action { get; set; }

    private bool IsAdmin;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            //Read admin state only once.
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                IsAdmin = user.IsInRole("Admin");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError("Status tile failed. {ex.Message}", ex);
        }
    }
}
