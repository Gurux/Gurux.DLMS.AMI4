@namespace Gurux.DLMS.AMI.Client.Pages.Config
@using Gurux.DLMS.AMI.Components.Enums

@if (Action != null)
{
    <div class="form-group">
        <label>@Title</label>
        <InputIntegerTimeSpan id="purge-interval" class="form-control"
                              Days="true"
                              TimeSpanUnit="TimeSpanUnit.Minute"
                              @bind-Value="Action.Interval" />
        <ValidationMessage For="@(() => Action.Interval)" />
        @ChildContent
        <label>@Properties.Resources.LastExecutionTime</label>&nbsp;
        @if (Action.Run != null)
        {
            <input class="form-control" type="text" readonly="readonly" value="@Action.Run.ToString()" />
        }
        else
        {
            <label>@Properties.Resources.Never</label>
        }
    </div>
}

@code {
    /// <summary>
    /// Custom child content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Prune title.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Prune action.
    /// </summary>
    [Parameter]
    public PruneBase? Action { get; set; }

}
