@using Gurux.DLMS.AMI.Shared.DIs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Gurux.DLMS.AMI.Shared.DTOs
@using Gurux.DLMS.AMI.Shared.Rest
@using Gurux.DLMS.AMI.Shared.Enums
@using Gurux.DLMS.AMI.Module
@using System.Globalization
@using Gurux.DLMS.AMI.Shared.DTOs.Enums
@using System.Text.Json

@attribute [Authorize(Roles = GXRoles.Admin + "," + GXRoles.ContentManager)]
@inject NavigationManager NavigationManager
@inject ILogger<Content> Logger
@inject HttpClient Http
@inject IGXNotifier2 Notifier
@if (Active != null)
{
    <EditForm Model="@Active">
        <div class="row">
            <div style="width:100%">
                <div class="form-group">
                    <InputNullableSwitch Text="@Properties.Resources.Active" @bind-Value="Active.Active" />
                </div>
                @if (action == CrudAction.Create)
                {
                    <div class="form-group">
                        <Label Required="true">Content type:</Label>
                        <DropdownSearch class="form-control"
                                        Id="Content-type"
                                        Formatter="@((GXContentType? e) => e?.Name)"
                                        LastValue="@(action == CrudAction.Create)"
                                        @bind-Value="Active.Type"
                                        OnSelected="@((GXContentType e) => OnValueChanged(e))"
                                        ItemsProvider="@GetContentTypes">
                        </DropdownSearch>
                    </div>
                }
                <FieldsEditor @ref="_fieldsEditor"></FieldsEditor>
                <ContentNotification Value="@Active"></ContentNotification>
                @if ((Active.Type?.Visibility & ContentVisibility.Start) != 0)
                {
                    <div class="form-group">
                        <label>@Properties.Resources.Publish</label>
                        <InputDate Type="@InputDateType.DateTimeLocal" id="publish" disabled="@IsDeleting" class="form-control"
                                   @bind-Value="Active.PublishTime" />
                    </div>
                }
                @if ((Active.Type?.Visibility & ContentVisibility.End) != 0)
                {
                    <div class="form-group">
                        <label>@Properties.Resources.EndTime</label>
                        <InputDate Type="@InputDateType.DateTimeLocal" id="endTime" disabled="@IsDeleting" class="form-control"
                                   @bind-Value="Active.EndTime" />
                    </div>
                }
                <AuthoringInformationDateTimeOffset Action="@Action" @bind-Creator="Active.Creator" CreationTime="@Active.CreationTime"
                                      Updated="@Active.Updated" @bind-Removed="Active.Removed" />
                @if (action == CrudAction.Delete)
                {
                    <hr />
                    <p>
                    </p>
                    <div class="form-group">
                        <InputRadioGroup @bind-Value="DeleteTarget">
                            <InputRadio Value="false">
                            </InputRadio>
                            <label>@Properties.Resources.TargetDisableQuestion</label><br>
                            <InputRadio Value="true">
                            </InputRadio>
                            <label>@Properties.Resources.TargetDeleteQuestion</label>
                        </InputRadioGroup>
                        <br />
                    </div>
                }
            </div>
        </div>
    </EditForm>
}
@code {
    [CascadingParameter]
    private ContentTab? Parent { get; set; }

    private FieldsEditor? _fieldsEditor;

    private GXContent? _active;

    private GXContent? Active
    {
        get
        {
            if (Parent?.Active != null)
            {
                return Parent.Active;
            }
            return _active;
        }
    }

    public void Update()
    {
        _fieldsEditor?.Update();
    }


    /// <summary>
    /// User action.
    /// </summary>
    [Parameter]
    public string? Action { get; set; }

    private CrudAction action;
    /// <summary>
    /// Selected item.
    /// </summary>
    [Parameter]
    public Guid? Id { get; set; }


    private bool DeleteTarget;
    private object? Target = null;

    /// <summary>
    /// Component parameters.
    ///</summary>
    List<GXKeyValuePair<string, object?>> _parameters = new List<GXKeyValuePair<string, object?>>();

    void UpdateParameterValue(string name, object? value)
    {
        if (Target != null)
        {
            var prop = Target.GetType().GetProperty(name);
            if (prop != null)
            {
                prop.SetValue(Target, Convert.ChangeType(value, prop.PropertyType));
            }
        }
    }

    /// <summary>
    /// User has selected the new content type and UI needs to update.
    /// </summary>
    protected void OnValueChanged(GXContentType value)
    {
        if (Active != null)
        {
            Active.Fields?.Clear();
            Active.Type = value;
            if (value.Fields != null)
            {
                foreach (var it in value.Fields)
                {
                    Active?.Fields?.Add(new GXContentField()
                    {
                        Type = it
                    });
                }
            }
            InvokeAsync(StateHasChanged);
            Update();
        }
    }

    public string? IsDeleting
    {
        get
        {
            if (Notifier.Action != CrudAction.Delete)
            {
                return null;
            }
            return "disabled";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Notifier.ProgressStart();
            Notifier.ClearStatus();
            Notifier.Clear();
            if (Active == null && Id != null)
            {
                //Get content data.
                var tmp = (await Http.GetAsJsonAsync<GetContentResponse>(string.Format("api/Content?id={0}", Id)));
                if (tmp?.Item != null)
                {
                    _active = tmp.Item;
                }
                else
                {
                    NavigationManager.NavigateTo("404");
                }
            }
            if (Active == null)
            {
                throw new ArgumentException(Properties.Resources.InvalidTarget);
            }
            action = ClientHelpers.GetAction(Action);
            if (action == CrudAction.Delete)
            {
                Notifier.AddMenuItem(new GXMenuItem() { Text = Properties.Resources.Remove, Icon = "oi oi-trash", OnClick = EventCallback.Factory.Create(this, OnSave) });
            }
            else
            {
                Notifier.AddMenuItem(new GXMenuItem( Properties.Resources.Save, "Save", EventCallback.Factory.Create(this, OnSave)));
            }
            Notifier.AddMenuItem(new GXMenuItem( Properties.Resources.Cancel, "Cancel", EventCallback.Factory.Create(this, OnCancel)));
            Notifier.UpdateButtons();
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            Notifier?.ProcessError(ex);
        }
        finally
        {
            Notifier?.ProgressEnd();
        }
    }

    /// <summary>
    /// Save content.
    /// </summary>
    public async void OnSave()
    {
        try
        {
            if (Active == null)
            {
                throw new Exception(Properties.Resources.InvalidTarget);
            }
            Notifier.ProgressStart();
            Notifier.ClearStatus();
            InvokeAsync(StateHasChanged);
            if (action == CrudAction.Delete)
            {
                await Http.PostAsJson<RemoveContentResponse>("api/Content/Delete", new RemoveContent()
                {
                    Ids = new Guid[] { Active.Id },
                    Delete = DeleteTarget
                });
            }
            else
            {
                string address;
                if (action == CrudAction.Create)
                {
                    address = "api/Content/Add";
                }
                else if (action == CrudAction.Update)
                {
                    address = "api/Content/Update";
                }
                else
                {
                    throw new Exception(Properties.Resources.InvalidTarget);
                }
                await Http.PostAsJson<UpdateContentResponse>(address, new UpdateContent() { Contents = new List<GXContent>() { Active } });
            }
            ClientHelpers.NavigateToLastPage(NavigationManager, Notifier);
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            Notifier?.ProcessError(ex);
        }
        finally
        {
            Notifier?.ProgressEnd();
        }
    }

    /// <summary>
    /// Cancel update.
    /// </summary>
    private void OnCancel()
    {
        ClientHelpers.NavigateToLastPage(NavigationManager, Notifier);
    }

    /// <summary>
    /// Filter is done when SearchSelectedByName is called.
    /// </summary>
    /// <param name="request"></param>
    /// <returns></returns>
    private async ValueTask<ItemsProviderResult<GXContentType?>> GetContentTypes(GXItemsProviderRequest request)
    {
        try
        {
            GXContentType? filter = new GXContentType()
            {
                Enumeration = false
            };
            if (!string.IsNullOrEmpty(request.Filter))
            {
                //Search content type by name
                filter.Name = request.Filter;
            }
            ListContentTypes req = new ListContentTypes()
            {
                Index = request.StartIndex,
                Count = request.Count,
                Filter = filter,
                OrderBy = request.OrderBy,
                Descending = request.Descending,
                AllUsers = request.ShowAllUserData,
                Select = [TargetType.ContentType]
            };
            var ret = await Http.PostAsJson<ListContentTypesResponse>("api/ContentType/List", req, request.CancellationToken);
            List<GXContentType> list = new();
            if (ret.ContentTypes != null)
            {
                list.AddRange(ret.ContentTypes);
            }
            if (Active?.Type != null)
            {
                foreach (var it in list)
                {
                    if (it.Id == Active.Type.Id)
                    {
                        Active.Type = it;
                        InvokeAsync(StateHasChanged);
                        break;
                    }
                }
            }
            else if (list.Any() && Active != null && action == CrudAction.Create)
            {
                //Select first item on create.
                OnValueChanged(list[0]);
            }
            return new ItemsProviderResult<GXContentType?>(list, ret.Count);
        }
        catch (Exception ex)
        {
            Notifier.ProcessError(ex);
        }
        return default;
    }
}

