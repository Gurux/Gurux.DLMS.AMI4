@using Gurux.DLMS.AMI.Shared.DTOs;
@using Gurux.DLMS.AMI.Shared.Enums;
@using Gurux.DLMS.AMI.Shared.Rest;
@using Gurux.DLMS.Enums;

@inject HttpClient Http
@inject IGXNotifier Notifier
<DropdownSearch class="form-control" disabled="@Disabled"
                Id="ContentDropdownSelector"
                Formatter="@((GXContent? e) => e?.Name)"
                LastValue="true"
                @bind-Value="Value"
                OnSelected="@((GXContent e) => OnValueChanged(e))"
                ItemsProvider="@GetContents">
</DropdownSearch>

@code {
    private GXContent? _value;

    /// <summary>
    /// Target content.
    /// </summary>
    [Parameter]
    public GXContent? Value
    {
        get
        {
            return _value;
        }
        set
        {
            if (value?.Id != _value?.Id)
            {
                _value = value;
            }
        }
    }

    /// <summary>
    /// Notified when value is updated.
    /// </summary>
    [Parameter]
    public EventCallback<GXContent?> ValueChanged { get; set; }

    /// <summary>
    /// Target content filter.
    /// </summary>
    [Parameter]
    public GXContent? Filter { get; set; }

    /// <summary>
    /// Notified when content filter is updated.
    /// </summary>
    [Parameter]
    public EventCallback<GXContent?> FilterChanged { get; set; }


    /// <summary>
    /// Is the content selector read-only.
    /// </summary>
    [Parameter]
    public bool Disabled
    {
        get;
        set;
    }

    [Parameter]
    public GXContentType? ContentType { get; set; }

    /// <summary>
    /// User has selected the new content type and UI needs to update.
    /// </summary>
    protected void OnValueChanged(GXContent? value)
    {
        if (ValueChanged.HasDelegate)
        {
            ValueChanged.InvokeAsync(value);
        }
    }

    private async ValueTask<ItemsProviderResult<GXContent?>> GetContents(GXItemsProviderRequest request)
    {
        //Don't clear status or error is lost.
        Notifier?.ProgressStart();
        try
        {
            if (Filter == null)
            {
                Filter = new GXContent();
            }
            if (Value?.Id is Guid id)
            {
                //If user modifies the content, we need to update the filter.
                Filter.Id = id;
            }
            else
            {
                //When user is created a new content.
                if (ContentType?.Id is Guid id2)
                {
                    //Get contents with type.
                    Filter.Type = new GXContentType()
                        {
                            Id = id2
                        };
                }
                if (!string.IsNullOrEmpty(request.Filter))
                {
                    Filter.Name = request.Filter;
                }
                else
                {
                    //Reset filter.
                    Filter.Name = null;
                }
            }
            ListContents req = new ListContents()
                {
                    Index = (int)request.StartIndex,
                    Count = (int)request.Count,
                    Filter = Filter,
                    OrderBy = request.OrderBy,
                    Descending = request.Descending,
                    AllUsers = request.ShowAllUserData,
                };
            var ret = await Http.PostAsJson<ListContentsResponse>("api/Content/List", req, request.CancellationToken);
            if (ret.Contents != null)
            {
                if (Value == null && ret.Contents.Any())
                {
                    //Select the first item when content is created.
                    Value = ret.Contents[0];
                    OnValueChanged(Value);
                }
                else if (ret.Contents.Length == 1)
                {
                    //Update value when it's read from the server.
                    _value = ret.Contents[0];
                    InvokeAsync(StateHasChanged);
                }
                return new ItemsProviderResult<GXContent?>(ret.Contents, ret.Count);
            }
        }
        catch (TaskCanceledException)
        {
            //Let the table component handle this.
            throw;
        }
        catch (Exception ex)
        {
            Notifier?.ProcessError(ex);
        }
        finally
        {
            Notifier?.ProgressEnd();
        }
        return default;
    }

    protected override void OnInitialized()
    {
        if (Filter == null)
        {
            Filter = new GXContent();
        }
    }
}
