@using Gurux.DLMS.AMI.Components.Accordion
@using Gurux.DLMS.AMI.Shared.DIs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Gurux.DLMS.AMI.Shared.DTOs
@using Gurux.DLMS.AMI.Shared.Rest
@using Gurux.DLMS.AMI.Shared.Enums
@using Gurux.DLMS.AMI.Module
@using System.Globalization
@using Gurux.DLMS.AMI.Shared.DTOs.Enums
@using System.Text.Json

@attribute [Authorize(Roles = GXRoles.Admin + ", " + GXRoles.ContentType,
            Policy = "@GXContentTypePolicies.View")]
@inject NavigationManager NavigationManager
@inject ILogger<ContentType> Logger
@inject HttpClient Http
@inject IGXNotifier2 Notifier

@if (Active != null)
{
    <EditForm Model="@Active">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <GXValidator @ref="_validator"
                     OnValidate="OnValidate" />
        <div class="row">
            <div style="width:100%">
                <div class="form-group">
                    <InputNullableSwitch Text="@Properties.Resources.Active" @bind-Value="Active.Active" />
                </div>
                <div class="form-group">
                                        <CopyLabel Value="@Active.Name">@Properties.Resources.Name</CopyLabel>
                    <InputText id="description" disabled="@IsDeleting" @bind-Value="Active.Name" class="form-control" />
                    <ValidationMessage For="@(() => Active.Name)" />
                </div>
                @if (Active.Enumeration == false)
                {
                    <div class="form-group">
                        <label>@Properties.Resources.Path</label>
                        <InputText id="path" disabled="@IsDeleting" @bind-Value="Active.Path" class="form-control" />
                        <ValidationMessage For="@(() => Active.Path)" />
                    </div>
                    <div class="form-group">
                        <InputSwitch Text="@Properties.Resources.Closable" @bind-Value="Closable" />
                        <InputSwitch Text="@Properties.Resources.Immediately" @bind-Value="Immediately" />
                        <InputSwitch Text="Promoted to front page." @bind-Value="Promoted" />
                        <InputSwitch Text="Add to user menu." @bind-Value="Menu" />
                    </div>
                    @if (Immediately == false)
                    {
                        <div class="form-group">
                            <label>@Properties.Resources.Publish</label>
                            <InputDate Type="@InputDateType.DateTimeLocal" id="publish" disabled="@IsDeleting" class="form-control"
                                       @bind-Value="Active.PublishTime" />
                        </div>
                    }
                }
            <div class="form-group">
                <label>@Properties.Resources.Description</label>
                <InputText id="title" disabled="@IsDeleting" @bind-Value="Active.Description" class="form-control" />
            </div>
                <CascadingValue Value="this">
                    <Fields Enumeration="@Active.Enumeration"></Fields>
                </CascadingValue>
                <AuthoringInformationDateTimeOffset Action="@Action" @bind-Creator="Active.Creator" CreationTime="@Active.CreationTime"
                                      Updated="@Active.Updated" @bind-Removed="Active.Removed" />
                @if (action == CrudAction.Delete)
                {
                    <hr />
                    <p>
                    </p>
                    <div class="form-group">
                        <InputRadioGroup @bind-Value="DeleteTarget">
                            <InputRadio Value="false">
                            </InputRadio>
                            <label>@Properties.Resources.TargetDisableQuestion</label><br>
                            <InputRadio Value="true">
                            </InputRadio>
                            <label>@Properties.Resources.TargetDeleteQuestion</label>
                        </InputRadioGroup>
                        <br />
                    </div>
                }
            </div>
        </div>
    </EditForm>
}
@code {
    [CascadingParameter]
    private ContentTypeTab? Parent { get; set; }

    private GXValidator? _validator;

    private GXContentType? _active;

    internal GXContentType? Active
    {
        get
        {
            if (Parent?.Active != null)
            {
                return Parent.Active;
            }
            return _active;
        }
    }

    void OnEdit(object? value)
    {

    }

    /// <summary>
    /// Is content closable.
    /// </summary>
    private bool Closable
    {
        get
        {
            return (Active?.Visibility & ContentVisibility.Closable) != 0;
        }
        set
        {
            if (value)
            {
                Active.Visibility |= ContentVisibility.Closable;
            }
            else
            {
                Active.Visibility &= ~ContentVisibility.Closable;

            }
        }
    }

    /// <summary>
    /// Is content released immediately.
    /// </summary>
    private bool Immediately
    {
        get
        {
            return (Active?.Visibility & ContentVisibility.Start) == 0;
        }
        set
        {
            if (value)
            {
                Active.Visibility &= ~ContentVisibility.Start;
            }
            else
            {
                Active.Visibility |= ContentVisibility.Start;
            }
        }
    }

    /// <summary>
    /// Is content promoted to front page.
    /// </summary>
    private bool Promoted
    {
        get
        {
            return (Active?.Visibility & ContentVisibility.Promoted) == 0;
        }
        set
        {
            if (value)
            {
                Active.Visibility &= ~ContentVisibility.Promoted;
            }
            else
            {
                Active.Visibility |= ContentVisibility.Promoted;
            }
        }
    }

    /// <summary>
    /// Is content type added to menu.
    /// </summary>
    private bool Menu
    {
        get
        {
            return (Active?.Visibility & ContentVisibility.Menu) == 0;
        }
        set
        {
            if (value)
            {
                Active.Visibility &= ~ContentVisibility.Menu;
            }
            else
            {
                Active.Visibility |= ContentVisibility.Menu;
            }
        }
    }


    /// <summary>
    /// User action.
    /// </summary>
    [Parameter]
    public string? Action { get; set; }

    private CrudAction action;
    /// <summary>
    /// Selected item.
    /// </summary>
    [Parameter]
    public Guid? Id { get; set; }

    private bool DeleteTarget;

    private object? Target = null;

    public string? IsDeleting
    {
        get
        {
            if (Notifier.Action != CrudAction.Delete)
            {
                return null;
            }
            return "disabled";
        }
    }

    /// <summary>
    /// Validate the object content.
    /// </summary>
    /// <param name="sender"></param>
    private void OnValidate(GXValidator sender)
    {
        if (Active != null)
        {
            if (string.IsNullOrEmpty(Active.Name))
            {
                sender.AddError(() => Active.Name, "Invalid name.");
            }
            if (Active.Enumeration == false && string.IsNullOrEmpty(Active.Path))
            {
                sender.AddError(() => Active.Path, "Invalid path.");
            }
        }
    }


    protected override async Task OnInitializedAsync()
    {
        try
        {
            Notifier.ProgressStart();
            Notifier.ClearStatus();
            Notifier.Clear();
            if (Active == null && Id != null)
            {
                //Get content type data.
                var tmp = (await Http.GetAsJsonAsync<GetContentTypeResponse>(string.Format("api/ContentType?id={0}", Id)));
                if (tmp?.Item != null)
                {
                    _active = tmp.Item;
                }
                else
                {
                    NavigationManager.NavigateTo("404");
                }
            }
            if (Active == null)
            {
                throw new ArgumentException(Properties.Resources.InvalidTarget);
            }
            action = ClientHelpers.GetAction(Action);
            if (action == CrudAction.Delete)
            {
                Notifier.AddMenuItem(new GXMenuItem() { Text = Properties.Resources.Remove, Icon = "oi oi-trash", OnClick = EventCallback.Factory.Create(this, OnSave) });
            }
            else
            {
                Notifier.AddMenuItem(new GXMenuItem( Properties.Resources.Save, "Save", EventCallback.Factory.Create(this, OnSave)));
            }
            Notifier.AddMenuItem(new GXMenuItem( Properties.Resources.Cancel, "Cancel", EventCallback.Factory.Create(this, OnCancel)));
            Notifier.UpdateButtons();
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            Notifier?.ProcessError(ex);
        }
        finally
        {
            Notifier?.ProgressEnd();
        }
    }

    /// <summary>
    /// Save content type.
    /// </summary>
    public async void OnSave()
    {
        try
        {
            if (Active == null)
            {
                throw new Exception(Properties.Resources.InvalidTarget);
            }
            _validator?.ClearErrors();
            if (_validator != null &&
                !_validator.Validate())
            {
                return;
            }
            Notifier.ProgressStart();
            Notifier.ClearStatus();
            InvokeAsync(StateHasChanged);
            if (action == CrudAction.Delete)
            {
                await Http.PostAsJson<RemoveContentTypeResponse>("api/ContentType/Delete", new RemoveContentType()
                    {
                        Ids = new Guid[] { Active.Id },
                        Delete = DeleteTarget
                    });
            }
            else
            {
                string address;
                if (action == CrudAction.Create)
                {
                    address = "api/ContentType/Add";
                }
                else if (action == CrudAction.Update)
                {
                    address = "api/ContentType/Update";
                }
                else
                {
                    throw new Exception(Properties.Resources.InvalidTarget);
                }
                await Http.PostAsJson<UpdateContentTypeResponse>(address, new UpdateContentType() { ContentTypes = new List<GXContentType>() { Active } });
            }
            ClientHelpers.NavigateToLastPage(NavigationManager, Notifier);
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        catch (Exception ex)
        {
            Notifier?.ProcessError(ex);
        }
        finally
        {
            Notifier?.ProgressEnd();
        }
    }

    public void Updated()
    {
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Cancel update.
    /// </summary>
    private void OnCancel()
    {
        ClientHelpers.NavigateToLastPage(NavigationManager, Notifier);
    }
}

