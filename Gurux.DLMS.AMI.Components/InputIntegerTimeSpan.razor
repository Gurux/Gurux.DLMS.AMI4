@using Gurux.DLMS.AMI.Components.Enums
@using System.Diagnostics.CodeAnalysis
@using System.Globalization

@inherits InputBase<int>
@if (Days == true)
{
    <span class="@(CssClass + ";inline-block")" @attributes="AdditionalAttributes">
        <input type="number" step="1" min="0" max="365"
               value="@GetDaysAsString()"
               onchange="@((ChangeEventArgs __e) => SetDaysAsString(__e.Value))" />
        <input type="time" step="@Step"
               value="@BindConverter.FormatValue(CurrentValueAsString)"
               onchange="@((ChangeEventArgs __e) => SetTimeAsString(__e.Value))" />
    </span>
}
else
{
    <input type="time" class="@CssClass" step="@Step"
           @attributes="AdditionalAttributes" value="@BindConverter.FormatValue(CurrentValueAsString)"
           onchange="@((ChangeEventArgs __e) => CurrentValueAsString = Convert.ToString(__e.Value))" />

}
@code {
    /// <summary>
    /// Value is get as a milliseconds.
    /// </summary>
    [Parameter]
    public TimeSpanUnit TimeSpanUnit { get; set; } = TimeSpanUnit.Second;

    /// <summary>
    /// Days is added to time span.
    /// </summary>
    [Parameter]
    public bool? Days { get; set; }


    private int Step
    {
        get
        {
            int value = 60;
            switch (TimeSpanUnit)
            {
                case TimeSpanUnit.Second:
                    value = 1;
                    break;
                case TimeSpanUnit.Minute:
                    value = 60;
                    break;
                case TimeSpanUnit.Hour:
                    value = 3600;
                    break;
                default:
                    break;
            }
            return value;
        }
    }



    protected override bool TryParseValueFromString(string? value,
    [MaybeNullWhen(false)] out int result,
    [NotNullWhen(false)] out string validationErrorMessage)
    {
        validationErrorMessage = "";
        try
        {
            if (value != null)
            {
                switch (TimeSpanUnit)
                {
                    case TimeSpanUnit.Second:
                        result = (int)TimeSpan.Parse(value).TotalSeconds;
                        break;
                    case TimeSpanUnit.Minute:
                        result = (int)TimeSpan.Parse(value).TotalMinutes;
                        break;
                    case TimeSpanUnit.Hour:
                        result = (int)TimeSpan.Parse(value).TotalHours;
                        break;
                    default:
                        result = 0;
                        break;
                }
            }
            else
            {
                result = 0;
            }
        }
        catch (Exception ex)
        {
            result = 0;
            validationErrorMessage = ex.Message;
            return false;
        }
        return true;
    }

    private void SetDaysAsString(object? value)
    {
        if (int.TryParse(Convert.ToString(value), out int tmp))
        {
            var days = TimeSpan.FromDays(tmp);
            TimeSpan ret;
            switch (TimeSpanUnit)
            {
                case TimeSpanUnit.Second:
                    ret = TimeSpan.FromSeconds(CurrentValue);
                    ret -= TimeSpan.FromDays((int)ret.TotalDays);
                    CurrentValue = (int)(days.TotalSeconds + ret.TotalSeconds);
                    break;
                case TimeSpanUnit.Minute:
                    ret = TimeSpan.FromMinutes(CurrentValue);
                    ret -= TimeSpan.FromDays((int)ret.TotalDays);
                    CurrentValue = (int)(days.TotalMinutes + ret.TotalMinutes);
                    break;
                case TimeSpanUnit.Hour:
                    ret = TimeSpan.FromHours(CurrentValue);
                    ret -= TimeSpan.FromDays((int)ret.TotalDays);
                    CurrentValue = (int)(days.TotalHours + ret.TotalHours);
                    break;
                default:
                    break;
            }
        }
    }

    private void SetTimeAsString(object? value)
    {
        if (TimeSpan.TryParse(Convert.ToString(value), out TimeSpan time))
        {
            var days = GetTime(CurrentValue);
            days = TimeSpan.FromDays((int)days.TotalDays);
            switch (TimeSpanUnit)
            {
                case TimeSpanUnit.Second:
                    CurrentValue = (int)(days.TotalSeconds + time.TotalSeconds);
                    break;
                case TimeSpanUnit.Minute:
                    CurrentValue = (int)(days.TotalMinutes + time.TotalMinutes);
                    break;
                case TimeSpanUnit.Hour:
                    CurrentValue = (int)(days.TotalHours + time.TotalHours);
                    break;
            }
        }
    }

    private string? GetDaysAsString()
    {
        string? result;
        switch (TimeSpanUnit)
        {
            case TimeSpanUnit.Second:
                result = TimeSpan.FromSeconds(CurrentValue).Days.ToString();
                break;
            case TimeSpanUnit.Minute:
                result = TimeSpan.FromMinutes(CurrentValue).Days.ToString();
                break;
            case TimeSpanUnit.Hour:
                result = TimeSpan.FromHours(CurrentValue).Days.ToString();
                break;
            default:
                result = null;
                break;
        }
        return result;
    }

    private TimeSpan GetTime(int value)
    {
        TimeSpan result;
        switch (TimeSpanUnit)
        {
            case TimeSpanUnit.Second:
                result = TimeSpan.FromSeconds(value);
                break;
            case TimeSpanUnit.Minute:
                result = TimeSpan.FromMinutes(value);
                break;
            case TimeSpanUnit.Hour:
                result = TimeSpan.FromHours(value);
                break;
            default:
                throw new ArgumentOutOfRangeException();
        }
        return result;
    }

    protected override string? FormatValueAsString(int value)
    {
        string result;
        switch (TimeSpanUnit)
        {
            case TimeSpanUnit.Second:
                result = TimeSpan.FromSeconds(value).ToString();
                break;
            case TimeSpanUnit.Minute:
                result = TimeSpan.FromMinutes(value).ToString("hh\\:mm");
                break;
            case TimeSpanUnit.Hour:
                result = TimeSpan.FromHours(value).ToString();
                break;
            default:
                result = "";
                break;
        }
        return result;
    }
}