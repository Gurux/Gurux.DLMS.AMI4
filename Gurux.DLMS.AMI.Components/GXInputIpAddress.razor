@using System.Diagnostics.CodeAnalysis
@using System.Globalization
@using Microsoft.Extensions.Logging
@using System.Net

@typeparam TItem

@inject IGXLocalStorage localStorage
@inject ILogger<GXDateTimeSelector<TItem>> Logger

<CascadingValue Value="this">
    <input id="@Id"
           value="@ValueToString()"
           placeholder="@Placeholder"
           class="@CssClass"
           attributes="@AdditionalAttributes"
           onreset="@(() => Reset())"
           onchange="@((ChangeEventArgs e) => UpdateIpAddress(e.Value))"
           required="@Required"
           readonly="readonly"
           aria-required="@Required" />
</CascadingValue>

@code
{

    /// <summary>
    /// ID is used to save cookie value.
    /// </summary>
    [Parameter]
    public string? Id
    {
        get;
        set;
    }

    /// <summary>
    /// Whether to store the value in a cookie.
    /// </summary>
    /// <seealso cref="Id"/>see
    [Parameter]
    public bool Save { get; set; } = true;

    /// <summary>
    /// Is datetime value required.
    /// </summary>
    [Parameter]
    public bool Required
    {
        get;
        set;
    }

    /// <summary>
    /// Constructor.
    /// </summary>
    public GXInputIpAddress()
    {
        Type type = Nullable.GetUnderlyingType(typeof(TItem)) ?? typeof(TItem);
        if (type != typeof(IPAddress) && type != typeof(UInt32) && type != typeof(UInt64) && type != typeof(string))
        {
            throw new InvalidOperationException($"Unsupported {GetType()} type param '{type}'.");
        }
    }

    /// <summary>
    /// Datetime value.
    /// </summary>
    [Parameter]
    public TItem? Value
    {
        get;
        set;
    }

    /// <summary>
    /// Reset value.
    /// </summary>
    private void Reset()
    {
        UpdateIpAddress(null);
    }

    /// <summary>
    /// Notified when the selected value is changed.
    /// </summary>
    [Parameter]
    public EventCallback<TItem?> ValueChanged
    {
        get;
        set;
    }

    private static string IpToString(UInt64 value)
    {
        string ip;
        if (value > UInt32.MaxValue)
        {
            var bytes = BitConverter.GetBytes(value);
            if (BitConverter.IsLittleEndian)
            {
                Array.Reverse(bytes);
            }
            ip = new IPAddress(bytes).ToString();
        }
        else
        {
            ip = new IPAddress((UInt32)value).ToString();
        }
        return ip;
    }

    private string? ValueToString()
    {
        if (Value is IPAddress ip)
        {
            return ip.ToString();
        }
        if (Value is UInt32 ipv4)
        {
            return IpToString(ipv4);
        }
        if (Value is UInt64 value)
        {
            return IpToString(value);
        }
        if (Value is string str)
        {
            return str;
        }
        return string.Empty;
    }

    [Parameter]
    public string? CssClass
    {
        get;
        set;
    } = "form-control";

    /// <summary>
    /// Placeholder text.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private void UpdateIpAddress(object? value, bool init = false)
    {
        bool change = false;
        if (value is string str &&
        !string.IsNullOrEmpty(str))
        {
            Value = default;
            if (System.Net.IPAddress.TryParse(str, out var ip))
            {
                throw new Exception("Invalid IP address.");
            }
            TItem? result;
            if (!BindConverter.TryConvertTo<TItem>(value, CultureInfo.InvariantCulture, out result))
            {
                throw new Exception("Invalid date time.");
            }
            change = Value?.ToString() != result?.ToString();
            Value = result;
            if (change)
            {
                if (ValueChanged.HasDelegate)
                {
                    ValueChanged.InvokeAsync(Value);
                }
            }
        }
        else
        {
            change = Value != null;
            Value = default;
            if (change)
            {
                if (ValueChanged.HasDelegate)
                {
                    ValueChanged.InvokeAsync(Value);
                }
            }
        }
        try
        {
            if (!init && Save && !string.IsNullOrEmpty(Id))
            {
                localStorage.SetValueAsync(null, Id, ValueToString());
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex.Message);
        }
    }

    /// <summary>
    /// Update default cookie value.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            try
            {
                if (Save && !string.IsNullOrEmpty(Id))
                {
                    string? str = await localStorage.GetValueAsync(Id);
                    UpdateIpAddress(str, true);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex.Message);
            }
        }
    }
}